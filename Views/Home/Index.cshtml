@model List<FixItNow.Models.Worker>
@{
    Layout = null; // Thêm dòng này để tắt Layout lồng nhau
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>FixItNow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Home.css">
</head>
<body>
    <nav class="navbar-custom">
        <div class="container nav-wrapper">
            <div class="logo">FixItNow</div>
            <div class="nav-actions">
                <div class="nav-guest">
                    <button class="btn-register">Đăng ký</button>
                    <button id="loginBtn" class="btn-login">Đăng nhập</button>
                </div>
                <div class="nav-user">
                    <div class="nav-icon">
                        <img src="assets/images/bell.png" alt="Thông báo">
                    </div>
                    <div class="user-dropdown">
                        <img id="userAvatar" src="assets/images/user.png" class="user-avatar" />
                        <div class="dropdown-menu">
                            <a href="#"><img src="assets/images/list.png" width="18"> Quản lý yêu cầu</a>
                            <a href="page/profile.html"><img src="assets/images/avatar.png" width="18"> Quản lý hồ sơ</a>
                            <a href="#" id="logoutBtn"><img src="assets/images/logout.png" width="18"> Đăng xuất</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero">
        <div class="container text-center">
            <h1 class="hero-title">
                <span class="static-text">Sửa chữa nhà cửa,</span>
                <span class="text-slider">
                    <span class="slider-track">
                        <span class="slide">thật dễ dàng.</span>
                        <span class="slide">nhanh chóng.</span>
                        <span class="slide">giá hợp lý.</span>
                    </span>
                </span>
            </h1>

            <form method="get" action="/Home/Index">
                <input type="hidden" name="category" id="categoryInput">
                <input type="hidden" name="location" id="locationInput">

                <div class="search-bar-wrapper">
                    <div class="search-bar">
                        <div class="search-section" id="categoryToggle">
                            <img src="assets/images/menu.png" class="search-icon">
                            <span id="categoryText">Danh mục sửa chữa</span>
                            <img src="assets/images/arrow-down.png" class="arrow-icon" id="categoryArrow">
                        </div>
                        <div class="divider"></div>
                        <div class="search-section location-shift" id="locationToggle">
                            <img src="assets/images/location.png" class="search-icon">
                            <span id="locationText">Địa điểm</span>
                            <img src="assets/images/arrow-down.png" class="arrow-icon" id="locationArrow">
                        </div>
                        <button type="submit" class="search-main-btn">Tìm thợ</button>
                    </div>

                    <div class="category-dropdown" id="categoryDropdown">
                        <div class="category-header">
                            <div class="search-input full">
                                <input type="text" id="categorySearch" placeholder="Nhập danh mục cần sửa chữa">
                            </div>
                        </div>
                        <div class="category-body">
                            <label class="category-item"><input type="checkbox" class="select-all"> Tất cả</label>
                            <label class="category-item"><input type="checkbox"> Điện lạnh</label>
                            <label class="category-item"><input type="checkbox"> Điện nước</label>
                            <label class="category-item"><input type="checkbox"> Máy giặt</label>
                            <label class="category-item"><input type="checkbox"> Điều hòa</label>
                            <label class="category-item"><input type="checkbox"> Tủ lạnh</label>
                            <label class="category-item"><input type="checkbox"> Ti vi</label>
                        </div>
                        <div class="category-footer">
                            <span class="clear-category">Bỏ tất cả</span>
                            <button class="apply-category">Áp dụng</button>
                        </div>
                    </div>

                    <div class="dropdown-panel location-popup" id="locationPanel">
                        <div class="location-header">
                            <div class="search-input">
                                <input type="text" id="provinceSearch" placeholder="Nhập Tỉnh/Thành phố">
                            </div>
                            <div class="search-input">
                                <input type="text" id="districtSearch" placeholder="Nhập Phường/Xã/Quận/Huyện">
                            </div>
                        </div>
                        <div class="location-body">
                            <div class="province-column" id="provinceColumn"></div>
                            <div class="district-column" id="districtColumn"></div>
                        </div>
                        <div class="location-footer">
                            <span class="clear-all" id="clearAll">Bỏ chọn tất cả</span>
                            <button class="apply-btn" id="saveLocation">Áp dụng</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <div class="container mt-5">
        <div class="row" id="workerList">
            @if (Model != null && Model.Any())
            {
                foreach (var w in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card p-3 shadow-sm border-0 h-100" 
                             style="border-radius:15px; cursor: pointer;" 
                             onclick="window.location.href='/Home/WorkerDetail/@w.Id'">
                             
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="text-success fw-bold mb-0">@w.Name</h5>
                                <span class="text-warning fw-bold mb-0 me-2">⭐ @w.Rating</span>
                            </div>
                            <p class="mb-1"><strong>Danh mục:</strong> @w.Category</p>
                            <p class="mb-0"><strong>Địa điểm:</strong> @w.Location</p>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    <p>Chưa có dữ liệu thợ sửa chữa phù hợp.</p>
                </div>
            }
        </div>
    </div>

    <script src="~/js/Home.js"></script>
</body>
</html>